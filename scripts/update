#!/usr/bin/env bash
set -e

cd "$(dirname "$0")"

usage() {
  cat <<EOF
Usage: $0 <command>

Commands:
  le-saviez-vous    Re-insert hardcoded Le saviez-vous facts
  scrape            Scrape Wikipedia archives (auto, incremental)
  ideas             Generate ideas via LLM (generate-ideas.ts)
  ingest            Ingest Wikipedia articles (ingest-wikipedia.ts)
  all               Run scrape + ideas + ingest
  seed              Run seed (topics + manual ideas)
  help              Show this help

Environment:
  OPENROUTER_API_KEY  Required for LLM commands
  LLM_API_KEY         Alternative API key
  NODE_TLS_REJECT_UNAUTHORIZED  Set to 0 for self-signed certs
EOF
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

export NODE_TLS_REJECT_UNAUTHORIZED=${NODE_TLS_REJECT_UNAUTHORIZED:-0}

case "$1" in
  le-saviez-vous)
    echo "📚 Inserting hardcoded Le saviez-vous facts..."
    npx tsx scripts/insert_saviez_vous.ts
    ;;

  scrape)
    echo "🌐 Scraping Wikipedia Le saviez-vous archives..."
    npx tsx scripts/scrape-saviez-vous.ts
    ;;


  ideas)
    echo "🚀 Generating ideas via LLM..."
    npx tsx src/scripts/generate-ideas.ts
    ;;

  ingest)
    echo "📖 Ingesting Wikipedia articles..."
    npx tsx src/scripts/ingest-wikipedia.ts
    ;;

  all)
    echo "🔄 Running full content update pipeline..."
    echo ""
    echo "=== Step 1: Scrape Wikipedia ==="
    npx tsx scripts/scrape-saviez-vous.ts
    echo ""
    echo "=== Step 2: Generate ideas ==="
    npx tsx src/scripts/generate-ideas.ts
    echo ""
    echo "=== Step 3: Ingest Wikipedia ==="
    npx tsx src/scripts/ingest-wikipedia.ts
    echo ""
    echo "✅ Full update complete!"
    ;;

  seed)
    echo "🌱 Running seed..."
    npx tsx prisma/seed.ts
    npx tsx src/scripts/seed-ideas.ts
    echo "✅ Seed complete!"
    ;;

  help|--help|-h)
    usage
    ;;

  *)
    echo "❌ Unknown command: $1"
    echo ""
    usage
    exit 1
    ;;
esac
