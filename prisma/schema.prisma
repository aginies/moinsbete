// This is your Prisma schema file
generator client {
  provider = "prisma-client"
  output   = "../src/generated"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  displayName   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookmarks     Bookmark[]
  following     Topic[]   @relation("UserFollowing")
  growthPlan    GrowthPlan?
  viewedIdeas   ViewedIdea[]
  resetTokens   PasswordResetToken[]
}

model Topic {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String   @default("📚")
  description String?
  color       String   @default("#6366f1")
  parentId    String?
  parent      Topic?   @relation("TopicHierarchy", fields: [parentId], references: [id])
  children    Topic[]  @relation("TopicHierarchy")
  collections Collection[]
  users       User[]   @relation("UserFollowing")
  createdAt   DateTime @default(now())
  sourceTopics SourceTopic[]
  ideaTopics  IdeaTopic[]
  suggestionParents TopicSuggestion[] @relation("ParentSuggestion")
  suggestionMerges  TopicSuggestion[] @relation("MergeRelation")

  @@index([parentId])
  @@index([slug])
}

model Source {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  author      String?
  type        SourceType @default(WIKIPEDIA)
  url         String?
  coverUrl    String?
  description String?
  ideas       Idea[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sourceTopics SourceTopic[]

  @@index([type])
  @@index([slug])
}

model SourceTopic {
  id      String @id @default(cuid())
  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  topicId  String
  topic    Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([sourceId, topicId])
}

model Idea {
  id          String   @id @default(cuid())
  title       String
  content     String
  takeaway    String
  saviezVous  String?
  slug        String   @unique
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id])
  orderIndex  Int      @default(0)
  isPublished Boolean  @default(true)
  bookmarks   Bookmark[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ideaTopics  IdeaTopic[]
  viewedIdeas ViewedIdea[]

  @@index([slug])
  @@index([isPublished])
  @@index([sourceId])
}

model IdeaTopic {
  id     String @id @default(cuid())
  ideaId String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  topicId String
  topic  Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([ideaId, topicId])
}

model Collection {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String   @unique
  isFeatured  Boolean  @default(false)
  topics      Topic[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isFeatured])
}

model Bookmark {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ideaId  String
  idea    Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, ideaId])
}

model GrowthPlan {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  streakDays     Int      @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TopicSuggestion {
  id            String   @id @default(cuid())
  categoryName  String
  parentId      String?
  parentTopic   Topic?   @relation("ParentSuggestion", fields: [parentId], references: [id])
  icon          String   @default("🤖")
  confidence    Float
  articleCount  Int      @default(0)
  status        SuggestionStatus @default(PENDING)
  mergedIntoId  String?
  mergedInto    Topic?   @relation("MergeRelation", fields: [mergedIntoId], references: [id])
  createdAt     DateTime @default(now())

  @@index([status])
}

model CommunityArticle {
  id          String   @id @default(cuid())
  title       String
  content     String
  slug        String   @unique
  author      String?
  excerpt     String?
  coverUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}

model ViewedIdea {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ideaId    String
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([userId, ideaId])
  @@index([userId, viewedAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  token      String   @unique
  email      String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([token])
  @@index([email])
}

model SaviezVousFact {
  id        String   @id @default(cuid())
  text      String
  sourceUrl String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

enum SourceType {
  WIKIPEDIA
  BOOK
  ARTICLE
  PODCAST
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
}
