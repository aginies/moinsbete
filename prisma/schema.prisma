generator client {
  provider        = "prisma-client"
  output          = "../src/generated"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String               @id @default(cuid())
  email        String               @unique
  passwordHash String
  displayName  String?
  role         UserRole @default(USER)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  bookmarks    Bookmark[]
  growthPlan   GrowthPlan?
  resetTokens  PasswordResetToken[]
  viewedIdeas  ViewedIdea[]
  following    Topic[]              @relation("UserFollowing")
}

model Topic {
  id                String            @id @default(cuid())
  name              String            @unique
  slug              String            @unique
  icon              String            @default("📚")
  description       String?
  color             String            @default("#6366f1")
  parentId          String?
  createdAt         DateTime          @default(now())
  ideaTopics        IdeaTopic[]
  sourceTopics      SourceTopic[]
  parent            Topic?            @relation("TopicHierarchy", fields: [parentId], references: [id])
  children          Topic[]           @relation("TopicHierarchy")
  suggestionMerges  TopicSuggestion[] @relation("MergeRelation")
  suggestionParents TopicSuggestion[] @relation("ParentSuggestion")
  collections       Collection[]      @relation("CollectionToTopic")
  users             User[]            @relation("UserFollowing")

  @@index([parentId])
  @@index([slug])
}

model Source {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  author       String?
  type         SourceType @default(WIKIPEDIA)
  url          String?
  coverUrl     String?
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ideas        Idea[]
  sourceTopics SourceTopic[]

  @@index([type])
  @@index([slug])
}

model SourceTopic {
  id       String @id @default(cuid())
  sourceId String
  topicId  String
  topic    Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, topicId])
}

model Idea {
  id          String       @id @default(cuid())
  title       String
  content     String
  takeaway    String
  saviezVous  String?
  slug        String       @unique
  sourceId    String
  orderIndex  Int          @default(0)
  isPublished Boolean      @default(true)
  isEnhanced  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  bookmarks   Bookmark[]
  source      Source       @relation(fields: [sourceId], references: [id])
  ideaTopics  IdeaTopic[]
  viewedIdeas ViewedIdea[]

  @@index([slug])
  @@index([isPublished])
  @@index([sourceId])
  @@index([isPublished, orderIndex])
  @@index([orderIndex])
}

model IdeaTopic {
  id      String @id @default(cuid())
  ideaId  String
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  idea    Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ideaId, topicId])
}

model Collection {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String   @unique
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topics      Topic[]  @relation("CollectionToTopic")

  @@index([slug])
  @@index([isFeatured])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  ideaId    String
  createdAt DateTime @default(now())
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId])
}

model GrowthPlan {
  id             String    @id @default(cuid())
  userId         String    @unique
  streakDays     Int       @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TopicSuggestion {
  id           String           @id @default(cuid())
  categoryName String
  parentId     String?
  icon         String           @default("🤖")
  confidence   Float
  articleCount Int              @default(0)
  status       SuggestionStatus @default(PENDING)
  mergedIntoId String?
  createdAt    DateTime         @default(now())
  mergedInto   Topic?           @relation("MergeRelation", fields: [mergedIntoId], references: [id])
  parentTopic  Topic?           @relation("ParentSuggestion", fields: [parentId], references: [id])

  @@index([status])
}

model CommunityArticle {
  id          String   @id @default(cuid())
  title       String
  content     String
  slug        String   @unique
  author      String?
  excerpt     String?
  coverUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}

model ViewedIdea {
  id       String   @id @default(cuid())
  userId   String
  ideaId   String
  viewedAt DateTime @default(now())
  idea     Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId])
  @@index([userId, viewedAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
}

model SaviezVousFact {
  id            String   @id @default(cuid())
  text          String
  createdAt     DateTime @default(now())
  sourceUrl     String?
  imageFilename String?

  @@index([createdAt])
}

enum UserRole {
  USER
  ADMIN
}

enum SourceType {
  WIKIPEDIA
  BOOK
  ARTICLE
  PODCAST
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
}
