generator client {
  provider        = "prisma-client"
  output          = "../src/generated"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String               @id @default(cuid())
  email           String               @unique
  passwordHash    String
  displayName     String?
  role            UserRole @default(USER)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  cnrsNewsEnabled Boolean              @default(true)
  wikipediaImageCardVisible Boolean     @default(true)
  saviezVousCardVisible Boolean         @default(true)
  radioFranceCardVisible Boolean        @default(true)
  imageWikimediaCardVisible Boolean     @default(true)
  imageWikiLovesCardVisible Boolean     @default(true)
  imageWikiLovesShowCategories Boolean  @default(true)
  imageWikimediaShowCategories Boolean  @default(true)
  imagePixabayCardVisible      Boolean  @default(true)
  imagePixabayShowCategories   Boolean  @default(true)
  bookmarks       Bookmark[]
  growthPlan      GrowthPlan?
  resetTokens     PasswordResetToken[]
  viewedIdeas     ViewedIdea[]
  following       Topic[]              @relation("UserFollowing")
  wikimediaTopics UserWikimediaTopic[]
}

model Topic {
  id                String            @id @default(cuid())
  name              String            @unique
  slug              String            @unique
  icon              String            @default("📚")
  description       String?
  color             String            @default("#6366f1")
  parentId          String?
  createdAt         DateTime          @default(now())
  ideaTopics        IdeaTopic[]
  sourceTopics      SourceTopic[]
  parent            Topic?            @relation("TopicHierarchy", fields: [parentId], references: [id])
  children          Topic[]           @relation("TopicHierarchy")
  suggestionMerges  TopicSuggestion[] @relation("MergeRelation")
  suggestionParents TopicSuggestion[] @relation("ParentSuggestion")
  collections       Collection[]      @relation("CollectionToTopic")
  users             User[]            @relation("UserFollowing")

  @@index([parentId])
  @@index([slug])
}

model Source {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  author       String?
  type         SourceType @default(WIKIPEDIA)
  url          String?
  coverUrl     String?
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ideas        Idea[]
  sourceTopics SourceTopic[]

  @@index([type])
  @@index([slug])
}

model SourceTopic {
  id       String @id @default(cuid())
  sourceId String
  topicId  String
  topic    Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, topicId])
}

model Idea {
  id          String       @id @default(cuid())
  title       String
  content     String
  takeaway    String
  saviezVous  String?
  slug        String       @unique
  sourceId    String
  orderIndex  Int          @default(0)
  isPublished Boolean      @default(true)
  isEnhanced  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  bookmarks   Bookmark[]
  source      Source       @relation(fields: [sourceId], references: [id])
  ideaTopics  IdeaTopic[]
   viewedIdeas ViewedIdea[]

   @@index([slug])
   @@index([isPublished])
   @@index([sourceId])
   @@index([isPublished, orderIndex])
   @@index([orderIndex])
   @@index([title])
}

model IdeaTopic {
  id      String @id @default(cuid())
  ideaId  String
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  idea    Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ideaId, topicId])
}

model Collection {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String   @unique
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topics      Topic[]  @relation("CollectionToTopic")

  @@index([slug])
  @@index([isFeatured])
}

model Bookmark {
  id           String            @id @default(cuid())
  userId       String
  ideaId       String?
  resourceId   String?
  type         BookmarkType      @default(IDEA)
  meta         Json?
  createdAt    DateTime          @default(now())
  lastReviewAt DateTime?
  nextReviewAt DateTime?
  reviewCount  Int              @default(0)
  easeFactor   Float            @default(2.5)
  idea         Idea?             @relation(fields: [ideaId], references: [id], onDelete: SetNull)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId])
  @@unique([userId, resourceId])
}

model GrowthPlan {
  id             String    @id @default(cuid())
  userId         String    @unique
  streakDays     Int       @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TopicSuggestion {
  id           String           @id @default(cuid())
  categoryName String
  parentId     String?
  icon         String           @default("🤖")
  confidence   Float
  articleCount Int              @default(0)
  status       SuggestionStatus @default(PENDING)
  mergedIntoId String?
  createdAt    DateTime         @default(now())
  mergedInto   Topic?           @relation("MergeRelation", fields: [mergedIntoId], references: [id])
  parentTopic  Topic?           @relation("ParentSuggestion", fields: [parentId], references: [id])

  @@index([status])
}

model ViewedIdea {
  id       String   @id @default(cuid())
  userId   String
  ideaId   String
  viewedAt DateTime @default(now())
  idea     Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId])
  @@index([userId, viewedAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
}

model SaviezVousFact {
  id            String   @id @default(cuid())
  text          String
  createdAt     DateTime @default(now())
  sourceUrl     String?
  imageFilename String?

  @@index([createdAt])
}

model UserWikimediaTopic {
  id          String   @id @default(cuid())
  userId      String
  topicId     String
  enabled     Boolean  @default(true)
  active      Boolean  @default(false)
  label       String?
  icon        String?
  searchTerms Json?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId])
}

enum UserRole {
  USER
  ADMIN
}

enum SourceType {
  WIKIPEDIA
  BOOK
  ARTICLE
  PODCAST
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
}

enum BookmarkType {
  IDEA
  RADIO_FRANCE
  CNRS_NEWS
  IMAGE_DU_JOUR
  SAVIEZ_VOUS
  IMAGE_WIKIMEDIA
  IMAGE_WIKILOVES
  IMAGE_PIXABAY
}

model CachedCnrsArticle {
  id         String   @id @default(cuid())
  title      String
  link       String   @unique
  imageUrl   String
  category   String
  scrapedAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}

model CachedRadioEpisode {
  id          String   @id @default(cuid())
  title       String
  description String?
  link        String   @unique
  imageUrl    String?
  audioUrl    String?
  radio       String
  scrapedAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
}

model CachedWikipediaImage {
  id          String   @id @default(cuid())
  imageUrl    String
  description String
  fileUrl     String
  date        String
  archive     String
  scrapedAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
  @@unique([imageUrl, date])
}

model CachedConfig {
  key   String @id
  value String
}

model CachedWikiLovesImage {
  id         String   @id @default(cuid())
  docid      String   @unique
  title      String
  author     String
  imageUrl   String
  commonsUrl String?
  license    String
  year       Int
  source     String
  scrapedAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
  @@index([source, year])
}
